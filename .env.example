# Supabase (required)
# Project URL: https://your-project.supabase.co
SUPABASE_URL=https://eastmqvhaydhpcssgjuo.supabase.co

# Service role key — SERVER SIDE ONLY (Cloudflare env vars)
# Never expose to browser — bypasses all RLS
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Vite-exposed variables — bundled into the client build
# Safe to expose: these are the publishable/anon key
VITE_SUPABASE_URL=https://eastmqvhaydhpcssgjuo.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here